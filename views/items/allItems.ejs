    <script>
        function toggleAlertPanel() {
            const box = document.getElementById("stockAlertBox");

            if (box.style.display === "none") {
                box.style.display = "block";
            } else {
                box.style.display = "none";
            }
        }

        // Ignore only for today
        function ignoreAlert() {
            const today = new Date().toISOString().slice(0, 10);
            localStorage.setItem("hideStockAlertDate", today);
            document.getElementById("stockAlertBox").style.display = "none";
        }

        // Auto hide if ignored today
        window.onload = function() {
            const today = new Date().toISOString().slice(0, 10);
            const hiddenDate = localStorage.getItem("hideStockAlertDate");

            if (hiddenDate === today) {
                const box = document.getElementById("stockAlertBox");
                if (box) box.style.display = "none";
            }
        };
    </script>